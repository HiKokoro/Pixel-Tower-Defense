static func _copy_recent_announcements(announcements: Array[Dictionary]) -> Array[Dictionary]:
	var recent_announcements: Array[Dictionary] = []
	var announcement_count := mini(announcements.size(), MAX_PLAYER_ANNOUNCEMENTS)
	for announcement_index in range(announcement_count):
		recent_announcements.append((announcements[announcement_index] as Dictionary).duplicate(true))
	return recent_announcements
