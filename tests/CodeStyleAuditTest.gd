var _failures: Array[String] = []


func _initialize() -> void:
	call_deferred("_run")


func _run() -> void:
	var files := _collect_audit_files()
	_assert(not files.is_empty(), "Code style audit should find GDScript files.")
	_assert(files.any(func(file_path: String) -> bool: return file_path.begins_with("res://scripts/")), "Code style audit should cover game scripts.")
	_assert(files.any(func(file_path: String) -> bool: return file_path.begins_with("res://tests/")), "Code style audit should cover test scripts.")
	_run_scanner_self_tests()

	for file_path in files:
		_scan_script_file(file_path)

	if _failures.is_empty():
		print("Code style audit passed.")
	else:
		for failure in _failures:
			push_error(failure)
		print("Code style audit failed.")

	quit(0 if _failures.is_empty() else 1)


func _collect_audit_files() -> Array[String]:
	var files: Array[String] = []
	for root_path in AUDIT_ROOTS:
		files.append_array(_collect_gd_files(root_path))
	files.sort()
	return files


func _run_scanner_self_tests() -> void:
	_assert(not _has_han_outside_string_or_comment("var message := \"中文显示文本\""), "Code style scanner should allow localized display strings.")
	_assert(not _has_han_outside_string_or_comment("# 中文注释可以保留"), "Code style scanner should allow localized comments.")
	_assert(not _has_han_outside_string_or_comment("var label := '中文单引号文本'"), "Code style scanner should allow single-quoted localized strings.")
	_assert(not _has_han_outside_string_or_comment("var escaped := \"\\\"中文\\\"\""), "Code style scanner should allow escaped quotes inside localized strings.")
	_assert(_has_han_outside_string_or_comment("var 中文变量 := 1"), "Code style scanner should reject localized identifiers.")
	_assert(_has_han_outside_string_or_comment("func 测试函数() -> void:"), "Code style scanner should reject localized function names.")
	_assert(not _is_multiline_token("return level_configs"), "Code style scanner should treat ordinary banned tokens as single-line checks.")
	_assert(_is_multiline_token("line one\nline two"), "Code style scanner should detect multi-line banned tokens for whole-file checks.")
	_assert(_get_token_start_line("alpha\nbeta\ngamma", "beta\ngamma") == 2, "Code style scanner should report the starting line for multi-line banned tokens.")
	_assert(_get_token_start_line("alpha\nbeta", "missing") == 0, "Code style scanner should return line zero for missing multi-line banned tokens.")


func _collect_gd_files(root_path: String) -> Array[String]:
	var files: Array[String] = []
	var directories: Array[String] = [root_path]

	while not directories.is_empty():
		var current_path: String = directories.pop_back()
		var dir: DirAccess = DirAccess.open(current_path)
		if dir == null:
			_failures.append("Cannot open directory: %s" % current_path)
			continue

		for file_name in dir.get_files():
			if file_name.ends_with(".gd"):
				files.append("%s/%s" % [current_path, file_name])

		for dir_name in dir.get_directories():
			if not dir_name.begins_with("."):
				directories.append("%s/%s" % [current_path, dir_name])

	files.sort()
	return files


func _scan_script_file(file_path: String) -> void:
	var file: FileAccess = FileAccess.open(file_path, FileAccess.READ)
	if file == null:
		_failures.append("Cannot open file: %s" % file_path)
		return

	var line_number := 0
	var file_lines: PackedStringArray = []
	while not file.eof_reached():
		line_number += 1
		var line := file.get_line()
		file_lines.append(line)
		if _has_han_outside_string_or_comment(line):
			_failures.append("%s:%d contains Chinese outside display strings or comments." % [file_path, line_number])
		if file_path.begins_with("res://scripts/"):
			for token in BANNED_SCRIPT_TOKENS.keys():
				if line.contains(str(token)):
					_failures.append("%s:%d %s" % [file_path, line_number, str(BANNED_SCRIPT_TOKENS[token])])
		if BANNED_FILE_TOKENS.has(file_path):
			var file_tokens: Dictionary = BANNED_FILE_TOKENS[file_path]
			for token in file_tokens.keys():
				var token_text := str(token)
				if not _is_multiline_token(token_text) and line.contains(token_text):
					_failures.append("%s:%d %s" % [file_path, line_number, str(file_tokens[token])])

	_scan_multiline_banned_tokens(file_path, "\n".join(file_lines))


func _scan_multiline_banned_tokens(file_path: String, file_text: String) -> void:
	if not BANNED_FILE_TOKENS.has(file_path):
		return

	var file_tokens: Dictionary = BANNED_FILE_TOKENS[file_path]
	for token in file_tokens.keys():
		var token_text := str(token)
		if _is_multiline_token(token_text):
			var line_number := _get_token_start_line(file_text, token_text)
			if line_number > 0:
				_failures.append("%s:%d %s" % [file_path, line_number, str(file_tokens[token])])


func _is_multiline_token(token: String) -> bool:
	return token.contains("\n")


func _get_token_start_line(file_text: String, token: String) -> int:
	var start_index := file_text.find(token)
	if start_index < 0:
		return 0

	var line_number := 1
	for index in range(start_index):
		if file_text.substr(index, 1) == "\n":
			line_number += 1
	return line_number


func _has_han_outside_string_or_comment(line: String) -> bool:
	var in_string := false
	var string_quote := ""
	var escaped := false

	for index in range(line.length()):
		var character := line.substr(index, 1)

		if in_string:
			if escaped:
				escaped = false
				continue
			if character == "\\":
				escaped = true
				continue
			if character == string_quote:
				in_string = false
				string_quote = ""
			continue

		if character == "#":
			return false
		if character == "\"" or character == "'":
			in_string = true
			string_quote = character
			continue
		if _is_han(character):
			return true

	return false


func _is_han(character: String) -> bool:
	if character.is_empty():
		return false
	var code: int = character.unicode_at(0)
	return code >= 0x4E00 and code <= 0x9FFF


func _assert(condition: bool, message: String) -> void:
	if condition:
		print("[PASS] %s" % message)
	else:
		_failures.append(message)
